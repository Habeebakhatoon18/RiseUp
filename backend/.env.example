# ===== DEPLOYMENT GUIDE =====
# For LOCAL development: use values below as-is
# For PRODUCTION deployment: 
#   1. Change NODE_ENV to "production"
#   2. Set your actual domain in CORS_ORIGIN
#   3. Set TRUST_PROXY=true if behind reverse proxy (nginx, load balancer)
#   4. Use proper MONGODB_URI (required in production)
#   5. Never commit .env — set vars in your deployment platform

# Server
# LOCAL: development | PRODUCTION: production
NODE_ENV=development
PORT=5000


MONGODB_URI=mongodb+srv://160623747018_db_user:fUrx4Qbwq3JTjPLR@cluster0.xzxqt0p.mongodb.net/?appName=Cluster0

# Security — CORS
# LOCAL dev: http://localhost:5173
# PRODUCTION: https://your-domain.com or https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Proxy configuration
# Set to "true" if deployed behind reverse proxy (Nginx, Load Balancer, etc.)
TRUST_PROXY=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BODY_LIMIT=1mb

# Optional — AI explanations fall back to rule-based text when unset
GEMINI_API_KEY=
